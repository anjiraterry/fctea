generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  role          Role            @default(VIEWER)
  preferences   Json?           @default("{\"theme\": \"light\", \"language\": \"en\", \"notifications\": true}")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bookmarks     Bookmark[]
  comments      Comment[]
  follows       Follow[]
  profile       Profile?
  reactions     Reaction[]
  revisions     Revision[]
  searchHistory SearchHistory[]
  sessions      Session[]
  views         View[]
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String?
  lastName  String?
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Brand {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  logo        String?
  coverImage  String?
  website     String?
  instagram   String?
  twitter     String?
  tiktok      String?
  verified    Boolean      @default(false)
  isFeatured  Boolean      @default(false)
  hotScore    Float        @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  blogs       Blog[]
  events      Event[]
  news        News[]
  people      Person[]
  places      Place[]
  collections Collection[] @relation("BrandToCollection")
}

model Area {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  places      Place[]
}

model PlaceCategory {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  places Place[]
}

model PlaceImage {
  id         String  @id @default(cuid())
  url        String
  alt        String?
  isFeatured Boolean @default(false)
  placeId    String
  place      Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)
}

model Place {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  description      String?
  address          String?
  coordinates      Json?
  phone            String?
  website          String?
  instagram        String?
  openingHours     Json?
  priceLevel       Int?
  rating           Float?
  hotScore         Float             @default(0)
  isFeatured       Boolean           @default(false)
  isPublished      Boolean           @default(true)
  brandId          String?
  categoryId       String?
  areaId           String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  events           Event[]
  externalMappings ExternalMapping[]
  area             Area?             @relation(fields: [areaId], references: [id])
  brand            Brand?            @relation(fields: [brandId], references: [id])
  category         PlaceCategory?    @relation(fields: [categoryId], references: [id])
  images           PlaceImage[]
  collections      Collection[]      @relation("CollectionToPlace")
  people           Person[]          @relation("PersonToPlace")
  tags             Tag[]             @relation("PlaceToTag")
}

model EventCategory {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  events Event[]
}

model Event {
  id               String            @id @default(cuid())
  title            String
  slug             String            @unique
  description      String?
  startDate        DateTime
  endDate          DateTime?
  venue            String?
  ticketUrl        String?
  organizer        String?
  price            String?
  hotScore         Float             @default(0)
  isFeatured       Boolean           @default(false)
  categoryId       String?
  brandId          String?
  placeId          String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  brand            Brand?            @relation(fields: [brandId], references: [id])
  category         EventCategory?    @relation(fields: [categoryId], references: [id])
  place            Place?            @relation(fields: [placeId], references: [id])
  externalMappings ExternalMapping[]
  media            Media[]
  collections      Collection[]      @relation("CollectionToEvent")
  people           Person[]          @relation("EventToPerson")
  tags             Tag[]             @relation("EventToTag")
}

model Person {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  bio         String?
  avatar      String?
  socialLinks Json?
  verified    Boolean  @default(false)
  hotScore    Float    @default(0)
  brandId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  brand       Brand?   @relation(fields: [brandId], references: [id])
  blogs       Blog[]   @relation("BlogToPerson")
  events      Event[]  @relation("EventToPerson")
  places      Place[]  @relation("PersonToPlace")
}

model News {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String
  featuredImage String?
  category      String?
  isBreaking    Boolean   @default(false)
  publishedAt   DateTime?
  hotScore      Float     @default(0)
  brandId       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  brand         Brand?    @relation(fields: [brandId], references: [id])
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  featuredImg String?
  brandId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  brand       Brand?   @relation(fields: [brandId], references: [id])
  people      Person[] @relation("BlogToPerson")
  tags        Tag[]    @relation("BlogToTag")
}

model Collection {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  featuredImg String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  brands      Brand[]  @relation("BrandToCollection")
  events      Event[]  @relation("CollectionToEvent")
  places      Place[]  @relation("CollectionToPlace")
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  slug   String  @unique
  blogs  Blog[]  @relation("BlogToTag")
  events Event[] @relation("EventToTag")
  places Place[] @relation("PlaceToTag")
}

model Media {
  id        String   @id @default(cuid())
  url       String
  type      String
  alt       String?
  eventId   String?
  createdAt DateTime @default(now())
  event     Event?   @relation(fields: [eventId], references: [id])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  targetId   String
  targetType String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reaction {
  id         String   @id @default(cuid())
  userId     String
  targetId   String
  targetType String
  type       String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  targetId   String
  targetType String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model View {
  id         String   @id @default(cuid())
  userId     String?
  targetId   String
  targetType String
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model TrendingScore {
  id         String   @id @default(cuid())
  targetId   String
  targetType String
  score      Float
  updatedAt  DateTime @updatedAt
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String?
  query     String
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id         String   @id @default(cuid())
  userId     String
  targetId   String
  targetType String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Draft {
  id         String   @id @default(cuid())
  targetType String
  content    Json
  editorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Revision {
  id         String   @id @default(cuid())
  targetId   String
  targetType String
  editorId   String
  diff       Json
  createdAt  DateTime @default(now())
  editor     User     @relation(fields: [editorId], references: [id])
}

model ScheduledPost {
  id         String   @id @default(cuid())
  targetId   String
  targetType String
  publishAt  DateTime
  createdAt  DateTime @default(now())
}

model HomepageSection {
  id         String   @id @default(cuid())
  title      String
  type       String
  order      Int
  contentIds String[]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FeaturedSection {
  id         String   @id @default(cuid())
  targetId   String
  targetType String
  order      Int
  createdAt  DateTime @default(now())
}

model ExternalSource {
  id       String            @id @default(cuid())
  name     String            @unique
  isActive Boolean           @default(true)
  mappings ExternalMapping[]
  syncLogs SyncLog[]
}

model ExternalMapping {
  id               String         @id @default(cuid())
  providerId       String
  internalEntityId String
  entityType       String
  sourceId         String
  lastSyncedAt     DateTime       @default(now())
  rawData          Json?
  source           ExternalSource @relation(fields: [sourceId], references: [id])
  event            Event?         @relation(fields: [internalEntityId], references: [id], map: "event_fk")
  place            Place?         @relation(fields: [internalEntityId], references: [id], map: "place_fk")

  @@unique([sourceId, providerId])
}

model SyncLog {
  id        String         @id @default(cuid())
  sourceId  String
  status    String
  message   String?
  createdAt DateTime       @default(now())
  source    ExternalSource @relation(fields: [sourceId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   Json?
  createdAt DateTime @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Report {
  id         String   @id @default(cuid())
  targetId   String
  targetType String
  reason     String
  userId     String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}

enum Role {
  VIEWER
  EDITOR
  ADMIN
}
